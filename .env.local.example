# Supabase — copy to .env.local and fill in your project values
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Email (Resend) — gửi email link đăng nhập khi tạo tài khoản học viên.
# Tạo API key tại https://resend.com và xác thực domain gửi.
# Nếu để trống, hệ thống vẫn tạo tài khoản bình thường nhưng KHÔNG gửi email.
RESEND_API_KEY=re_your_api_key_here
# Địa chỉ "from" — phải thuộc domain bạn đã xác thực trên Resend.
EMAIL_FROM=Kế hoạch Tập luyện <no-reply@your-domain.com>
